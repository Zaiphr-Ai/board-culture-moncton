---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navigation from "@/components/common/Navigation.astro";
import Footer from "@/components/common/Footer.astro";
import Hero from "@/components/sections/Hero.astro";
import Button from "@/components/ui/Button.astro";
import FeaturedProducts from "@/components/sections/FeaturedProducts.astro";
import TeamRiders from "@/components/sections/TeamRiders.astro";
import LocalSpots from "@/components/sections/LocalSpots.astro";
import ShopCategories from "@/components/sections/ShopCategories.astro";
import EventsCalendar from "@/components/sections/EventsCalendar.astro";
import BrandWall from "@/components/sections/BrandWall.astro";

const navLinks = [
  { label: "Home", href: "#" },
  { label: "Shop", href: "#shop" },
  { label: "Team", href: "#team" },
  { label: "Spots", href: "#spots" },
  { label: "Events", href: "#events" },
];
---

<BaseLayout>
  <Navigation links={navLinks} />

  <!-- Hero with background image and grain -->
  <div class="relative">
    <img
      src="https://picsum.photos/seed/skateboard-action/1600/900"
      alt=""
      role="presentation"
      width="1600"
      height="900"
      class="absolute inset-0 w-full h-full object-cover brightness-[.2]"
    />
    <div class="absolute inset-0 grain-texture"></div>
    <Hero
      headline="SHRED MONCTON"
      subheadline="Underground skate shop. Real riders. No posers."
      class="min-h-screen relative z-10"
    >
      <Button variant="primary" size="lg" href="#shop" data-animate="fade-up" data-delay="0.4">
        Shop Decks
      </Button>
      <Button variant="outline" size="lg" href="#team" data-animate="fade-up" data-delay="0.5">
        Meet the Team
      </Button>
    </Hero>
  </div>

  <!-- Featured Products -->
  <FeaturedProducts />

  <!-- Team Riders -->
  <TeamRiders />

  <!-- Local Spots -->
  <LocalSpots />

  <!-- Shop Categories -->
  <ShopCategories />

  <!-- Events Calendar -->
  <EventsCalendar />

  <!-- Brand Wall -->
  <BrandWall />

  <!-- Footer Info Section -->
  <section class="border-t-4 border-primary bg-background pt-16 pb-8" data-animate="fade-up">
    <div class="container-fluid">
      <div class="grid gap-8 grid-cols-1 md:grid-cols-3">
        <!-- Shop Info -->
        <div class="rotate-1">
          <h3 class="font-heading font-bold text-fluid-xl text-primary uppercase tracking-wider mb-4">
            Board Culture
          </h3>
          <div class="font-mono text-sm space-y-2 text-foreground/70">
            <p>123 Main Street</p>
            <p>Moncton NB E1C 1B9</p>
            <p class="text-secondary">(506) 555-SKRT</p>
            <p class="text-accent">shred@boardculturemoncton.ca</p>
          </div>
        </div>

        <!-- Hours -->
        <div class="-rotate-2">
          <h3 class="font-heading font-bold text-fluid-xl text-secondary uppercase tracking-wider mb-4">
            Hours
          </h3>
          <div class="font-mono text-sm space-y-2 text-foreground/70">
            <p>Mon-Fri: 11am - 7pm</p>
            <p>Saturday: 10am - 8pm</p>
            <p>Sunday: 12pm - 6pm</p>
          </div>
        </div>

        <!-- Social -->
        <div class="rotate-1">
          <h3 class="font-heading font-bold text-fluid-xl text-accent uppercase tracking-wider mb-4">
            Follow Us
          </h3>
          <div class="font-mono text-sm space-y-2">
            <a href="#" class="block text-foreground/70 hover:text-primary hover:animate-text-glow transition-none">
              Instagram: @boardculturemoncton
            </a>
            <a href="#" class="block text-foreground/70 hover:text-primary hover:animate-text-glow transition-none">
              Facebook: /boardculturemoncton
            </a>
            <a href="#" class="block text-foreground/70 hover:text-primary hover:animate-text-glow transition-none">
              TikTok: @bcmskate
            </a>
          </div>

          <div class="mt-6 inline-block border border-accent px-3 py-1 rotate-3">
            <span class="font-mono text-xs text-accent uppercase tracking-widest">
              Coming Soon: Online Store
            </span>
          </div>
        </div>
      </div>

      <div class="mt-12 text-center">
        <p class="font-mono text-sm text-foreground/40">
          Moncton's skate shop since 2024. Stay local.
        </p>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
